# Alternative Time - Produccion en Render

# Entorno general
APP_ENV=production
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=<GENERATED_DJANGO_SECRET_KEY>
DJANGO_LOG_LEVEL=INFO

# Hosts y seguridad
# Backend host publico de Render, por ejemplo:
# DJANGO_ALLOWED_HOSTS=alternative-time-api.onrender.com
DJANGO_ALLOWED_HOSTS=<RENDER_BACKEND_HOST>

# Frontend host publico de Render, por ejemplo:
# FRONTEND_HOST=alternative-time-web.onrender.com
FRONTEND_HOST=<RENDER_FRONTEND_HOST>

# Si prefieres dejarlo explicito:
# DJANGO_CORS_ALLOWED_ORIGINS=https://alternative-time-web.onrender.com
DJANGO_CORS_ALLOWED_ORIGINS=https://<RENDER_FRONTEND_HOST>
DJANGO_CORS_ALLOWED_ORIGIN_REGEXES=
DJANGO_CSRF_TRUSTED_ORIGINS=https://<RENDER_FRONTEND_HOST>

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Base de datos
# En Render lo ideal es usar DATABASE_URL desde Postgres administrado.
DB_ENGINE=postgres
DATABASE_URL=<RENDER_DATABASE_URL>
POSTGRES_SSL_REQUIRE=True
POSTGRES_CONN_MAX_AGE=60

# Fallback si no usas DATABASE_URL.
POSTGRES_DB=<RENDER_POSTGRES_DB>
POSTGRES_USER=<RENDER_POSTGRES_USER>
POSTGRES_PASSWORD=<RENDER_POSTGRES_PASSWORD>
POSTGRES_HOST=<RENDER_POSTGRES_HOST>
POSTGRES_PORT=5432

# Desarrollo local solamente. No se usa si DB_ENGINE=postgres.
SQLITE_NAME=db.sqlite3

# Legacy import opcional
# Ajusta esta ruta solo si vas a ejecutar import_legacy_data en produccion.
LEGACY_IMPORT_USERNAME=<LEGACY_IMPORT_USERNAME>
LEGACY_IMPORT_PASSWORD=<LEGACY_IMPORT_PASSWORD>
